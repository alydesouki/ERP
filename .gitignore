# See https://docs.github.com/en/get-started/getting-started-with-git/ignoring-files for more about ignoring files.

# compiled output
dist
tmp
out-tsc
*.tsbuildinfo
.expo
.expo-shared

# dependencies
node_modules

# IDEs and editors
/.idea
.project
.classpath
.c9/
*.launch
.settings/
*.sublime-workspace

# IDE - VSCode
.vscode/*
!.vscode/settings.json
!.vscode/tasks.json
!.vscode/launch.json
!.vscode/extensions.json

# misc
/.sass-cache
/connect.lock
/coverage
/libpeerconnection.log
npm-debug.log
yarn-error.log
testem.log
/typings

# System Files
.DS_Store
Thumbs.db

.cursor/rules/nx-rules.mdc
.github/instructions/nx.instructions.md

# Replit
.cache/
.local/

# ── Licensing Security ──────────────────────────────────────────────────────
# CRITICAL: Never commit the private key or any generated license files.
# The private key must be stored separately and securely by the vendor.

# Private key files — MUST NEVER be committed
private.pem
*.pem
private-key.*

# Generated license files — customer-specific, never store in repo
license.dat
license-generator/output/

# License generator tool directory — keep out of ERP builds
# (already excluded via electron-builder.yml !licensing/tools/**/* rule)
artifacts/desktop/licensing/tools/
